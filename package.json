{
  "name": "pvs-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "setup:check": "node scripts/setup-check.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "notebook:docx": "node scripts/notebook-to-docx.mjs",
    "notebook:import": "powershell -ExecutionPolicy Bypass -File scripts/import-to-onenote.ps1",
    "postinstall": "prisma generate || true"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.39.5",
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.97",
    "@vercel/analytics": "^1.4.1",
    "class-variance-authority": "^0.7.0",
    "cloudinary": "^2.5.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.0",
    "lucide-react": "^0.456.0",
    "maplibre-gl": "^5.24.0",
    "next": "^15.5.16",
    "qrcode": "^1.5.4",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-hook-form": "^7.53.2",
    "svix": "^1.41.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.16",
    "heic-convert": "^2.1.0",
    "html-to-docx": "^1.8.0",
    "marked": "^18.0.4",
    "postcss": "^8.5.10",
    "prisma": "^5.22.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vercel": "^56.4.1"
  },
  "overrides": {
    "tar": "^7.5.19",
    "js-yaml": "^4.3.0",
    "minimatch@10": "^10.2.3",
    "glob@10": "^10.5.0",
    "ajv@8": "^8.17.2",
    "@tootallnate/once": "^2.0.1",
    "esbuild": "^0.28.1",
    "smol-toml": "^1.6.1",
