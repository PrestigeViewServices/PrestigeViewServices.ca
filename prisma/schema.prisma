// Prisma schema — Phase 1 portal.
//
// Run `npm run db:generate` after `npm install`.
// Run `npm run db:migrate` once you have a DATABASE_URL pointed at a
// Postgres instance (Neon or Supabase recommended for v1).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Users
// -----------------------------------------------------------------------------
// Mirrored from Clerk via webhook (see app/api/clerk/webhook/route.ts).
// `role` is the canonical authorization signal — Clerk's publicMetadata.role
// is kept in sync so middleware can gate routes without a DB hit on every
// request.
//
// `ULTIMATE_ADMIN` is never assignable via UI — only via the env allowlist
// (ULTIMATE_ADMIN_EMAILS) on user creation in the Clerk webhook.

enum Role {
  ULTIMATE_ADMIN
  SUPER_ADMIN // Photo + hiring management only; cannot change roles or access billing.
  ADMIN
  MANAGER // Ops + dispatch; NO finance edits (invoices). Reaches /admin.
  EMPLOYEE
  REP // Door-to-door sales / door-hanger rep. Reaches /rep only.
  CUSTOMER
}

enum SignupMethod {
  GOOGLE
  APPLE
  EMAIL
  PHONE
  OTHER
}

model User {
  id            String       @id // Clerk user id
  email         String       @unique
  firstName     String?
  lastName      String?
  phone         String?
  // Customer profile fields. Optional on every role; only the customer area
  // exposes / edits them. Editing is Phase 2 (see /account TODO).
  streetAddress String?
  city          String?
  region        String?
  postalCode    String?
  role          Role         @default(CUSTOMER)
  signupMethod  SignupMethod @default(OTHER)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  assignedSupport SupportRequest[] @relation("AssignedSupport")
  uploadedPhotos  GalleryImage[]   @relation("UploadedPhotos")

  // Field-service ops (Phase 1 dashboard)
  customer        Customer?     @relation("CustomerUser")
  crewMemberships CrewMember[]  @relation("CrewMemberUser")
  activityLogs    ActivityLog[] @relation("ActorLogs")

  // Canvassing (door-to-door)
  knocks         Knock[]         @relation("RepKnocks")
  locationPings  RepLocation[]   @relation("RepPings")
  hangerSessions HangerSession[] @relation("RepHangerSessions")
}

// -----------------------------------------------------------------------------
// Careers applications
// -----------------------------------------------------------------------------
// Written by /api/apply when DB is configured. Falls back to email-only
// (lib/send-application-email.ts) when DATABASE_URL is missing — applications
// are NEVER silently dropped.

enum ApplicationStatus {
  NEW
  CONTACTED
  HIRED
  REJECTED
}

model Application {
  id              String            @id @default(cuid())
  name            String
  phone           String
  email           String
  roleSlug        String // slug from lib/content/careers.ts
  availability    String
  validLicense    String
  reliableCommute String
  yearsExperience String
  whyJoin         String?
  resumeUrl       String?
  status          ApplicationStatus @default(NEW)
  /// Internal hiring notes. Factual only — visible to admins.
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status])
  @@index([roleSlug])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// Support requests
// -----------------------------------------------------------------------------
// NOTE: This may duplicate functionality in AuroraSuite (our CRM for sales
// leads). Confirm with the team before treating this as the source of truth
// for customer issues. For Phase 1 we ship it because /support needs SOME
// backend — we can migrate to Aurora later if it fits.

enum SupportType {
  QUOTE
  ISSUE
  DISPATCH
  GENERAL
}

enum SupportStatus {
  NEW
  IN_PROGRESS
  RESOLVED
}

// -----------------------------------------------------------------------------
// Gallery images
// -----------------------------------------------------------------------------
// Managed by ultimate_admin + super_admin via /admin/site/photos. Photos
// themselves live on Cloudinary (see lib/cloudinary.ts) — we only store the
// hosted URL + metadata here.
//
// Soft-delete via `active`. Keeps history reversible and lets us audit
// who pulled what.

model GalleryImage {
  id           String   @id @default(cuid())
  /// Full hosted URL (Cloudinary)
  url          String
  /// Cloudinary public_id, used to delete from the host on hard-purge
  publicId     String?
  /// Required alt text — accessibility + SEO
  alt          String
  /// Which on-site section this image belongs to (e.g. "home", "lawnpros")
  section      String
  /// Optional caption shown under the photo on the public site
  caption      String?
  /// Lower = earlier in the grid
  sortOrder    Int      @default(0)
  /// Soft delete flag — hidden from public + admin grid when false
  active       Boolean  @default(true)
  /// Clerk userId of whoever uploaded (FK to User)
  uploadedById String?
  uploadedBy   User?    @relation("UploadedPhotos", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([section, active, sortOrder])
}

model SupportRequest {
  id              String        @id @default(cuid())
  name            String
  email           String
  phone           String
  type            SupportType
  propertyAddress String?
  details         String
  status          SupportStatus @default(NEW)
  assignedToId    String?
  assignedTo      User?         @relation("AssignedSupport", fields: [assignedToId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// Winter package reservations
// -----------------------------------------------------------------------------
// Customer-facing reservation requests submitted from /winter-packages.
// "Reserve" here means quote request, not paid booking — admin follows up
// to confirm price and take payment offline. Pricing is defined in
// lib/content/winter-packages.ts; the estimate captured at submission is
// frozen in `estimateLowCents` / `estimateHighCents` so we can compare to
// the final price the customer ultimately pays.

enum DrivewayTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum DrivewaySize {
  ONE_CAR
  TWO_CAR
  THREE_PLUS_CAR
}

enum ShovelingTier {
  NONE
  PASS_10
  PASS_15
  PASS_25
  PASS_50
}

enum ReservationStatus {
  NEW
  CONTACTED
  CONFIRMED
  DECLINED
  COMPLETED
}

// -----------------------------------------------------------------------------
// Multi-service quote requests
// -----------------------------------------------------------------------------
// Submitted from /estimate — customer can bundle window cleaning, pressure
// washing, and/or gutter cleaning. `services` is a JSON array because the
// shape of each line item is service-specific (different inputs per service).
// Server-side, we recompute the price + bundle discount on every submission
// using lib/content/service-estimator.ts so the customer can't tamper.

enum QuoteStatus {
  NEW
  CONTACTED
  QUOTED
  BOOKED
  DECLINED
  COMPLETED
}

model QuoteRequest {
  id            String  @id @default(cuid())
  name          String
  email         String
  phone         String
  streetAddress String
  city          String
  region        String  @default("ON")
  postalCode    String?

  /// JSON array: [{ slug, selections: {...}, priceCents }]
  services          Json
  subtotalCents     Int
  discountCents     Int
  estimateLowCents  Int
  estimateHighCents Int

  customerNotes String?
  notes         String?
  status        QuoteStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model WinterReservation {
  id            String  @id @default(cuid())
  name          String
  email         String
  phone         String
  streetAddress String
  city          String
  region        String  @default("ON")
  postalCode    String?

  drivewayTier  DrivewayTier
  drivewaySize  DrivewaySize
  shovelingTier ShovelingTier @default(NONE)

  /// Estimate captured at submission time, in CAD cents.
  estimateLowCents  Int
  estimateHighCents Int

  /// Optional notes from the customer (gate code, dogs, etc.)
  customerNotes String?
  /// Internal admin notes — visible to admins only.
  notes         String?
  status        ReservationStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// =============================================================================
// FIELD-SERVICE OPS  (internal dashboard — Phase 1 schema)
// =============================================================================
// Customers, their properties + service bundles (accounts), the job pipeline
// (leads → jobs), recurring contracts, crews, invoices (STATUS ONLY — there is
// NO payment processing / Stripe), reviews, and an audit log.
//
// Money is integer CAD cents everywhere (never floats), matching the existing
// QuoteRequest / WinterReservation convention.
//
// Phase gating: all tables are created now for stable migrations, but UI is
// built per phase. RecurringContract auto-generation + lifecycle triggers are
// Phase 2; Route/Review modules are Phase 3 (tables exist now).

enum Division {
  LAWNPROS
  CLEARVIEW
  SNOWLAND
}

enum LeadStatus {
  NEW
  QUOTED
  WON
  LOST
}

enum LeadSource {
  PUBLIC_FORM
  PORTAL
  MANUAL
  PHONE
  DOOR_TO_DOOR
}

enum JobStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETE
  INVOICED
  CANCELED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

enum ContractStatus {
  ACTIVE
  PAUSED
  EXPIRED
  CANCELED
}

enum ContractFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  PER_STORM
  SEASONAL
}

enum ReviewStatus {
  REQUESTED
  RECEIVED
}

// -----------------------------------------------------------------------------
// Customer — CRM record. Decoupled from the Clerk `User`: most customers are
// created by an admin from a lead and never log in. `userId` links to a User
// only when portal access is granted (Phase 2).
// -----------------------------------------------------------------------------
model Customer {
  id        String   @id @default(cuid())
  firstName String
  lastName  String?
  email     String?
  phone     String?
  userId    String?  @unique
  user      User?    @relation("CustomerUser", fields: [userId], references: [id])
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties Property[]
  accounts   Account[]
  leads      Lead[]
  reviews    Review[]

  @@index([lastName, firstName])
  @@index([email])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// Property — a service address owned by a customer. A customer can have many.
// -----------------------------------------------------------------------------
model Property {
  id            String   @id @default(cuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label         String? // "Home", "Rental on Pine St"
  streetAddress String
  city          String
  region        String   @default("ON")
  postalCode    String?
  /// Reserved for the Phase 3 route / map view.
  lat           Float?
  lng           Float?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  jobs      Job[]
  contracts RecurringContract[]

  @@index([customerId])
  @@index([city])
}

// -----------------------------------------------------------------------------
// Account — a customer's bundle of active services. Holds lifetime value and
// the winter-only upsell flag (snow customer with no summer service).
// `ltvCents` and `winterOnly` are maintained by app logic (recompute helpers).
// -----------------------------------------------------------------------------
model Account {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String?
  ltvCents   Int      @default(0)
  winterOnly Boolean  @default(false)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  jobs      Job[]
  contracts RecurringContract[]
  invoices  Invoice[]

  @@index([customerId])
  @@index([winterOnly])
  @@index([active])
}

// -----------------------------------------------------------------------------
// Service — catalog item, scoped to a division. Mirrors lib/content/divisions.ts
// service slugs (lawn-mowing, window-cleaning, snow-removal, ...).
// -----------------------------------------------------------------------------
model Service {
  id                String   @id @default(cuid())
  division          Division
  slug              String   @unique
  name              String
  description       String?
  defaultPriceCents Int?
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())

  jobs      Job[]
  contracts RecurringContract[]

  @@index([division, active])
}

// -----------------------------------------------------------------------------
// RecurringContract — a standing agreement (weekly lawn, per-storm snow, ...).
// Auto-generates Job records on its schedule (Phase 2). `lastGeneratedAt` tracks
// the generator's high-water mark.
// -----------------------------------------------------------------------------
model RecurringContract {
  id              String            @id @default(cuid())
  accountId       String
  account         Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  propertyId      String
  property        Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  division        Division
  serviceId       String?
  service         Service?          @relation(fields: [serviceId], references: [id])
  frequency       ContractFrequency
  status          ContractStatus    @default(ACTIVE)
  priceCents      Int
  startDate       DateTime
  endDate         DateTime?
  lastGeneratedAt DateTime?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  jobs Job[]

  @@index([status])
  @@index([division])
  @@index([endDate])
}

// -----------------------------------------------------------------------------
// Lead — top of the pipeline. Arrives from the public form (PUBLIC_FORM), the
// portal, or manual entry. `customerId` is null until converted to a Customer.
// When WON, a Job is scheduled and `customerId` is linked.
// -----------------------------------------------------------------------------
model Lead {
  id              String     @id @default(cuid())
  customerId      String?
  customer        Customer?  @relation(fields: [customerId], references: [id])
  name            String
  email           String
  phone           String
  propertyAddress String?
  division        Division?
  /// Service slugs of interest — shape varies per service, so JSON array.
  serviceSlugs    Json?
  message         String?
  status          LeadStatus @default(NEW)
  source          LeadSource @default(PUBLIC_FORM)
  estimateCents   Int?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  jobs   Job[]
  knocks Knock[]

  @@index([status])
  @@index([source])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// Crew — a field team (e.g. "Truck 1"). Has members and is assigned jobs.
// -----------------------------------------------------------------------------
model Crew {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  members CrewMember[]
  jobs    Job[]
  routes  Route[]

  @@index([active])
}

model CrewMember {
  id        String   @id @default(cuid())
  crewId    String
  crew      Crew     @relation(fields: [crewId], references: [id], onDelete: Cascade)
  /// Optional link to the Clerk User (employee) for the crew portal.
  userId    String?
  user      User?    @relation("CrewMemberUser", fields: [userId], references: [id])
  name      String
  title     String?
  createdAt DateTime @default(now())

  @@index([crewId])
  @@index([userId])
}

// -----------------------------------------------------------------------------
// Route — a crew's ordered set of jobs for a day. UI is Phase 3 (map view).
// -----------------------------------------------------------------------------
model Route {
  id        String   @id @default(cuid())
  crewId    String
  crew      Crew     @relation(fields: [crewId], references: [id], onDelete: Cascade)
  date      DateTime
  name      String?
  createdAt DateTime @default(now())

  jobs Job[]

  @@index([crewId, date])
}

// -----------------------------------------------------------------------------
// Job — a single unit of field work. Links to a property + crew, and to EITHER
// a won Lead (one-off) or a RecurringContract (in practice exactly one is set;
// enforced in app logic). Crew completes it with notes + Cloudinary photos.
// Complete → auto-creates a draft Invoice (Phase 2 trigger).
// -----------------------------------------------------------------------------
model Job {
  id           String             @id @default(cuid())
  accountId    String?
  account      Account?           @relation(fields: [accountId], references: [id])
  propertyId   String
  property     Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  division     Division
  serviceId    String?
  service      Service?           @relation(fields: [serviceId], references: [id])
  leadId       String?
  lead         Lead?              @relation(fields: [leadId], references: [id])
  contractId   String?
  contract     RecurringContract? @relation(fields: [contractId], references: [id])
  crewId       String?
  crew         Crew?              @relation(fields: [crewId], references: [id])
  routeId      String?
  route        Route?             @relation(fields: [routeId], references: [id])
  status       JobStatus          @default(SCHEDULED)
  scheduledFor DateTime?
  completedAt  DateTime?
  priceCents   Int?
  crewNotes    String?
  /// Cloudinary URLs uploaded by the crew on completion.
  photoUrls    String[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  invoice Invoice?
  review  Review?

  @@index([status])
  @@index([scheduledFor])
  @@index([crewId, scheduledFor])
  @@index([accountId])
  @@index([propertyId])
}

// -----------------------------------------------------------------------------
// Invoice — STATUS TRACKING ONLY. No payment processor, no Stripe. Created as a
// DRAFT when a job completes; status advanced manually (sent/paid/overdue).
// -----------------------------------------------------------------------------
model Invoice {
  id          String        @id @default(cuid())
  accountId   String
  account     Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  jobId       String?       @unique
  job         Job?          @relation(fields: [jobId], references: [id])
  number      String?       @unique
  status      InvoiceStatus @default(DRAFT)
  amountCents Int
  dueDate     DateTime?
  issuedAt    DateTime?
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([dueDate])
  @@index([accountId])
}

// -----------------------------------------------------------------------------
// Review — request-sent / review-received tracking. Module UI is Phase 3.
// -----------------------------------------------------------------------------
model Review {
  id          String       @id @default(cuid())
  customerId  String?
  customer    Customer?    @relation(fields: [customerId], references: [id])
  jobId       String?      @unique
  job         Job?         @relation(fields: [jobId], references: [id])
  status      ReviewStatus @default(REQUESTED)
  rating      Int?
  requestedAt DateTime     @default(now())
  receivedAt  DateTime?
  externalUrl String?

  @@index([status])
}

// -----------------------------------------------------------------------------
// ActivityLog — append-only audit trail written by server actions (status
// changes, completions, conversions). Powers recent-activity surfaces.
// -----------------------------------------------------------------------------
model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("ActorLogs", fields: [actorId], references: [id])
  /// e.g. "Lead", "Job", "Invoice", "Account"
  entityType String
  entityId   String
  /// e.g. "created", "status_changed", "completed", "converted"
  action     String
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// =============================================================================
// CANVASSING  (door-to-door sales + door-hanger routes)
// =============================================================================
// Every civic address in the target towns (Petawawa, Pembroke, Deep River,
// Chalk River) is pre-loaded from Statistics Canada's Open Database of
// Addresses via scripts/import-oda-addresses.mjs. Reps knock doors from the
// /rep mobile app; each visit is a Knock, and the address carries a
// denormalized `status` (latest meaningful outcome) so the map can color
// ~20k dots without joining knocks.

enum CanvassStatus {
  NOT_VISITED
  NOT_HOME
  NOT_INTERESTED
  FOLLOW_UP
  QUOTE_GIVEN
  SOLD
  DO_NOT_KNOCK
}

enum KnockOutcome {
  NOT_HOME
  NOT_INTERESTED
  FOLLOW_UP
  QUOTE_GIVEN
  SOLD
  DO_NOT_KNOCK
}

model CanvassAddress {
  id          String        @id @default(cuid())
  /// StatCan ODA row id — lets re-imports skip rows we already have.
  odaId       String?       @unique
  civicNumber String
  street      String
  unit        String?
  /// Display town: Petawawa | Pembroke | Deep River | Chalk River
  city        String
  postalCode  String?
  lat         Float
  lng         Float
  status      CanvassStatus @default(NOT_VISITED)
  lastKnockAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  knocks Knock[]

  @@index([city, status])
  @@index([status])
}

// A single door-knock visit. QUOTE_GIVEN / SOLD auto-create a Lead in the
// existing pipeline (source DOOR_TO_DOOR) — see /api/canvass/knock.
model Knock {
  id           String         @id @default(cuid())
  addressId    String
  address      CanvassAddress @relation(fields: [addressId], references: [id], onDelete: Cascade)
  repId        String
  rep          User           @relation("RepKnocks", fields: [repId], references: [id])
  outcome      KnockOutcome
  note         String?
  contactName  String?
  contactPhone String?
  /// When FOLLOW_UP: when the rep promised to come back.
  callbackAt   DateTime?
  leadId       String?
  lead         Lead?          @relation(fields: [leadId], references: [id])
  createdAt    DateTime       @default(now())

  @@index([repId, createdAt])
  @@index([addressId])
  @@index([createdAt])
}

// GPS breadcrumb from the rep app (every ~20s while open). Powers the admin
// "live map" (latest ping per rep) and traces door-hanger session routes.
model RepLocation {
  id         String         @id @default(cuid())
  repId      String
  rep        User           @relation("RepPings", fields: [repId], references: [id], onDelete: Cascade)
  lat        Float
  lng        Float
  accuracy   Float?
  sessionId  String?
  session    HangerSession? @relation(fields: [sessionId], references: [id])
  recordedAt DateTime       @default(now())

  @@index([repId, recordedAt])
  @@index([sessionId, recordedAt])
}

// A door-hanger run. The rep starts it, walks the neighbourhood (pings are
// tagged with the session), and ends it with a hanger count — so admin sees
// exactly which streets were covered, traced from GPS.
model HangerSession {
  id          String    @id @default(cuid())
  repId       String
  rep         User      @relation("RepHangerSessions", fields: [repId], references: [id], onDelete: Cascade)
  city        String?
  /// Free-text neighbourhood / street label typed by the rep.
  area        String?
  hangerCount Int       @default(0)
  notes       String?
  startedAt   DateTime  @default(now())
  endedAt     DateTime?

  pings RepLocation[]

  @@index([repId, startedAt])
  @@index([startedAt])
}

// =============================================================================
// FIRST-PARTY WEB ANALYTICS
// =============================================================================
// Privacy-friendly page-view tracking stored in our own database — no external
// analytics service. One row per page view; `visitorId` is an anonymous
// HMAC of (ip + user-agent + UTC day) so uniques can be counted per day
// without storing anything personally identifying. Admin traffic is excluded
// at the API layer.

model PageView {
  id        String   @id @default(cuid())
  /// Pathname only — never query strings (they can carry personal data).
  path      String
  /// Referrer hostname (e.g. "google.com"), null for direct visits.
  referrer  String?
  /// Anonymous daily-rotating visitor hash.
  visitorId String
  /// "mobile" | "tablet" | "desktop"
  device    String?
  /// ISO country code from the hosting edge, when available.
  country   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([visitorId, createdAt])
}

// =============================================================================
// THE PRESTIGE CLUB — customer loyalty program + portal
// =============================================================================
// Portal accounts are fully in-house (email + password, scrypt hashes, signed
// session cookies) — no external auth service. Members are matched to Jobber
// clients by email, with an admin "link account" fallback.
//
// POINTS ARE REAL MONEY (100 pts = $5 CAD service credit). The ledger
// (PointsTransaction) is APPEND-ONLY: every balance is derived by summing the
// ledger; no mutable balance column exists anywhere. Money is integer cents.
//
// Public category labels only — internal division names must never surface
// in portal UI, URLs, or emails.

enum LoyaltyTier {
  MEMBER
  INSIDER
  ELITE
  PRESTIGE
}

enum PointsType {
  EARN_SERVICE
  EARN_REVIEW
  EARN_REFERRAL
  EARN_CROSS_CATEGORY
  EARN_SNOW_EARLYBIRD
  EARN_BIRTHDAY
  REDEEM
  EXPIRE
  ADMIN_ADJUST
}

enum RedemptionStatus {
  REQUESTED
  APPROVED
  APPLIED
  DECLINED
}

enum ReferralStatus {
  INVITED
  BOOKED
  COMPLETED
  AWARDED
}

enum ClubTicketType {
  QUOTE
  BOOK_SERVICE
  ISSUE
  BILLING
  CALLBACK
}

enum ClubTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum PublicCategory {
  WINDOW_EXTERIOR
  LAWN_CARE
  SNOW_REMOVAL
}

enum VeteranStatus {
  NONE
  SELF_DECLARED
  VERIFIED
}

enum ServiceRecordStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum GiveawayStatus {
  DRAFT
  OPEN
  CLOSED
  DRAWN
}

/// A portal account. Auth identity + credentials; loyalty data hangs off
/// CustomerProfile. Passwords are scrypt hashes (lib/customer-auth.ts).
model Member {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String?
  phone        String?
  /// Shareable referral code (e.g. "JORDAN-4X2K"), generated on first visit
  /// to the referrals page. /r/[code] resolves it.
  referralCode String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile         CustomerProfile?
  points          PointsTransaction[]
  redemptions     Redemption[]
  referralsMade   Referral[]          @relation("Referrer")
  tickets         ClubTicket[]
  giveawayEntries GiveawayEntry[]
  serviceRecords  ServiceRecord[]
  reviewClaims    ReviewClaim[]
}

enum ReviewClaimStatus {
  PENDING
  AWARDED
  REJECTED
}

/// "I left a Google review" self-reports, verified manually by admin before
/// the one-time 250-point bonus posts to the ledger.
model ReviewClaim {
  id        String            @id @default(cuid())
  memberId  String
  member    Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  status    ReviewClaimStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([status])
  @@index([memberId])
}

model CustomerProfile {
  id       String @id @default(cuid())
  memberId String @unique
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  /// Jobber client id once linked (email match or admin fallback).
  jobberClientId String? @unique
  streetAddress  String?
  city           String?
  region         String? @default("ON")
  postalCode     String?
  /// 1-12; used for the birthday bonus (Phase 2 automation).
  birthdayMonth  Int?
  veteranStatus  VeteranStatus @default(NONE)
  /// Cached tier — recalculated on every paid-invoice sync from the rolling
  /// 12-month paid spend. Display convenience only; spend is the truth.
  tier           LoyaltyTier   @default(MEMBER)
  /// Rolling 12-month paid spend in CAD cents (recomputed, not authoritative).
  tierSpend12moCents Int @default(0)
  /// Email notification preferences.
  notifyServiceReminders Boolean @default(true)
  notifyPromos           Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// APPEND-ONLY points ledger. Never update or delete rows; corrections are
/// new ADMIN_ADJUST entries. Balance = SUM(amount) per member.
model PointsTransaction {
  id       String     @id @default(cuid())
  memberId String
  member   Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  type     PointsType
  /// Whole points, positive (earn) or negative (redeem/expire/adjust-down).
  amount   Int
  /// What produced this entry (service record id, referral id, admin ref).
  sourceRef String?
  /// Human-readable reason shown in the customer ledger.
  note      String?
  createdAt DateTime @default(now())

  @@index([memberId, createdAt])
  @@index([type])
}

model Redemption {
  id       String           @id @default(cuid())
  memberId String
  member   Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  /// Points spent (positive number, e.g. 500 = $25 credit).
  points   Int
  /// Credit value in CAD cents (points * 5).
  creditCents Int
  status   RedemptionStatus @default(REQUESTED)
  /// Jobber invoice the credit was applied to (admin fills on APPLIED).
  appliedInvoiceRef String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([memberId])
}

model Referral {
  id            String         @id @default(cuid())
  code          String         @unique
  referrerId    String
  referrer      Member         @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredEmail String?
  status        ReferralStatus @default(INVITED)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([referrerId])
  @@index([status])
}

/// Customer request / callback ticket. Distinct from the public SupportRequest
/// form: these belong to a signed-in member and carry a message thread.
model ClubTicket {
  id       String           @id @default(cuid())
  memberId String
  member   Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  type     ClubTicketType
  subject  String
  /// "phone" | "email" | "text"
  preferredContact String?
  /// Free-text preferred time window, e.g. "Weekdays after 4pm".
  timeWindow       String?
  status   ClubTicketStatus @default(OPEN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ClubTicketMessage[]

  @@index([status])
  @@index([memberId, createdAt])
}

model ClubTicketMessage {
  id       String     @id @default(cuid())
  ticketId String
  ticket   ClubTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  /// "member" or "admin".
  authorType String
  /// Internal admin notes are never shown to the customer.
  internal   Boolean @default(false)
  body       String
  createdAt  DateTime @default(now())

  @@index([ticketId, createdAt])
}

model Giveaway {
  id          String         @id @default(cuid())
  title       String
  prize       String
  status      GiveawayStatus @default(DRAFT)
  opensAt     DateTime?
  closesAt    DateTime?
  drawnAt     DateTime?
  winnerEntryId String?
  /// Skill-testing question result recorded for the winner (CA compliance).
  skillTestResult String?
  createdAt   DateTime @default(now())

  entries GiveawayEntry[]
}

model GiveawayEntry {
  id         String   @id @default(cuid())
  giveawayId String
  giveaway   Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  memberId   String?
  member     Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  /// "tier" | "referral" | "no_purchase" (mail-in / free web form entries).
  source     String
  createdAt  DateTime @default(now())

  @@index([giveawayId])
}

/// Cached Jobber job/invoice data mapped to PUBLIC category labels. The
/// original Jobber names may contain internal division terms — only the
/// mapped category and a scrubbed title are ever rendered.
model ServiceRecord {
  id       String  @id @default(cuid())
  memberId String?
  member   Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  jobberJobId     String? @unique
  jobberInvoiceId String?
  category        PublicCategory
  /// Customer-safe title, e.g. "Exterior window cleaning".
  title           String
  serviceDate     DateTime
  address         String?
  status          ServiceRecordStatus @default(SCHEDULED)
  amountCents     Int                 @default(0)
  paid            Boolean             @default(false)
  paidAt          DateTime?
  photoUrls       String[]            @default([])
  /// Guards against double-awarding EARN_SERVICE points for this record.
  pointsAwarded   Boolean             @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId, serviceDate])
  @@index([status])
  @@index([paid])
}

/// Admin-editable program numbers (point values, redemption rate, tier
/// thresholds). Keys are defined in lib/club-settings.ts; missing keys fall
/// back to code defaults. Changes affect FUTURE awards only — the ledger is
/// never rewritten.
model ClubSetting {
  key       String   @id
  value     Int
  updatedAt DateTime @updatedAt
}

/// Admin-editable mapping from Jobber line-item / job-name terms to public
/// categories, so internal names never leak into the portal.
model CategoryMapping {
  id        String         @id @default(cuid())
  /// Case-insensitive substring matched against Jobber job/line names.
  matchTerm String         @unique
  category  PublicCategory
  createdAt DateTime       @default(now())
}
