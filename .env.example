# =============================================================================
# Prestige View Services — environment variables
# =============================================================================
#
# 1. COPY THIS FILE to .env.local in the same folder (the .local file is
#    ignored by git so your real secrets never get committed).
# 2. Fill in the values below. Every line has a comment explaining what it is
#    and EXACTLY where to get it.
# 3. Run `npm run setup:check` to confirm everything is wired up before
#    starting the app.
#
# Full step-by-step (with screenshots-level detail) lives in SETUP.md.
# =============================================================================


# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------

# The public URL of your site. Used for sitemap, Open Graph, and SEO.
# In dev, leave it as the production URL — Next.js handles the localhost rewrite.
NEXT_PUBLIC_SITE_URL=https://prestigeviewservices.ca

# Business phone in E.164 format. Powers the click-to-call button.
NEXT_PUBLIC_BUSINESS_PHONE=+1-613-334-5858


# -----------------------------------------------------------------------------
# Clerk (authentication)  —  REQUIRED for /admin, /portal, /sign-in
# -----------------------------------------------------------------------------
# Where to get these:
#   1. Sign up at https://dashboard.clerk.com
#   2. Click "Create application"
#   3. Pick the sign-in methods you want (Google, Apple, Email, Phone)
#   4. After creation, click "API Keys" in the sidebar
#   5. Copy each value below.
# Full walkthrough: SETUP.md → "Step 3: Create your Clerk app"

# Starts with `pk_test_` in development, `pk_live_` in production.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Starts with `sk_test_` in development, `sk_live_` in production.
# NEVER commit this. NEVER paste it in Slack/email/screenshots.
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Webhook signing secret. Get it from:
#   Clerk Dashboard → Webhooks → (click your endpoint) → Signing Secret
# Starts with `whsec_`. See SETUP.md → "Step 8: Set up the Clerk webhook".
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME

# (optional) URL overrides if you change the auth route layout. Defaults work.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/post-sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/post-sign-in


# -----------------------------------------------------------------------------
# Ultimate-admin allowlist  —  REQUIRED
# -----------------------------------------------------------------------------
# Comma-separated list of emails that AUTOMATICALLY become "ultimate_admin"
# on first sign-in.
#
# The ultimate_admin role is the ONLY role that can:
#   - View and change every user's role in /admin/users
#   - Access /admin/site (site-modifications surface)
#
# You CANNOT promote someone to ultimate_admin from the UI — it is set here
# only. Add at least your own email (and any business partner who needs
# top-level access).
#
# Examples:
#   ULTIMATE_ADMIN_EMAILS=owner@prestigeviewservices.ca
#   ULTIMATE_ADMIN_EMAILS=owner@prestigeviewservices.ca,partner@prestigeviewservices.ca
ULTIMATE_ADMIN_EMAILS=REPLACE_WITH_YOUR_EMAIL@prestigeviewservices.ca


# -----------------------------------------------------------------------------
# Database (Postgres)  —  REQUIRED for admin dashboard data
# -----------------------------------------------------------------------------
# Where to get this:
#   OPTION A — Neon (recommended, free, takes ~2 min):
#     1. Sign up at https://console.neon.tech
#     2. Create a new project (pick the region closest to you)
#     3. On the dashboard click "Connect"
#     4. Copy the full connection string under "Connection string"
#        (make sure "Pooled connection" is OFF for migrations — see SETUP.md)
#   OPTION B — Supabase:
#     1. Sign up at https://supabase.com
#     2. Create a new project
#     3. Project Settings → Database → Connection string → URI
#
# It must start with `postgresql://` or `postgres://` and end with `?sslmode=require`.
# Full walkthrough: SETUP.md → "Step 5: Create your database"
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require


# -----------------------------------------------------------------------------
# Cloudinary (image host)  —  REQUIRED for /admin/site/photos uploads
# -----------------------------------------------------------------------------
# Where to get these:
#   1. Sign up at https://cloudinary.com (the free tier is plenty for Phase 1)
#   2. Click the gear icon → Settings → API Keys
#   3. Copy the three values below
# Your cloud name appears in the dashboard URL: cloudinary.com/console/cloud_name/...
# Uploaded photos land in pvs/gallery/<section> for organization.

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=your-cloudinary-api-secret


# -----------------------------------------------------------------------------
# Notification emails (optional — separate inboxes per channel on purpose)
# -----------------------------------------------------------------------------
# These power the email-stub notifiers in lib/send-*-email.ts.
# Until you wire a real provider (Resend / SMTP), they're used as the "To"
# field in the server log so requests are easy to trace.

APPLICATION_NOTIFICATION_EMAIL=hiring@prestigeviewservices.ca
SUPPORT_NOTIFICATION_EMAIL=support@prestigeviewservices.ca


# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------
# Vercel Analytics auto-enables when deployed to Vercel — no key needed.
# Google Analytics 4 requires a measurement ID, available in GA4:
#   Admin → Data Streams → Web → look for `G-XXXXXXX`
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
